import pandas as pd

# Load the dataset
df = pd.read_csv('bird_tracking_1.csv')

# 1. Check the unique values in the target
print("Unique values in Migration_Success:")
print(df['Migration_Success'].unique())

# 2. Count how many distinct classes there are
print(f"\nNumber of unique classes: {df['Migration_Success'].nunique()}")

# 3. Check the class distribution (balance)
print("\nValue counts:")
print(df['Migration_Success'].value_counts())

# 4. Check class balance as proportions
print("\nClass proportions:")
print(df['Migration_Success'].value_counts(normalize=True))

# 5. Check for missing values
print(f"\nMissing values in target: {df['Migration_Success'].isna().sum()}")

# 6. Check the dtype (confirms it's categorical, not numeric)
print(f"\nDtype: {df['Migration_Success'].dtype}")


import pandas as pd

df = pd.read_csv('bird_tracking_1.csv')

# Group by species, take top 5 speeds per group, average them, sort descending
result = (df.groupby('Species')['Speed_kmph']
            .apply(lambda x: x.nlargest(5).mean())
            .sort_values(ascending=False))

print(result)
print(f'\nWinner: {result.idxmax()} with {result.max():.2f} kmph')


import pandas as pd

df = pd.read_csv('bird_tracking_1.csv')

# Filter to Cranes only
cranes = df[df['Species'] == 'Crane']

# Success rate = proportion of 'Successful' migrations × 100
success_rate = (cranes['Migration_Success'] == 'Successful').mean() * 100

print(f'Migration success rate for Cranes: {success_rate:.1f}%')


import pandas as pd

df = pd.read_csv('bird_tracking_1.csv')

# Convert 2100 miles to km using the prescribed conversion (1 mile = 1.6 km)
distance_km = 2100 * 1.6   # = 3360.0 km

# Time (minutes) = (distance / speed) * 60
df['time_minutes'] = (distance_km / df['Speed_kmph']) * 60

# Find the minimum time
fastest_time = df['time_minutes'].min()
print(f'{fastest_time:.1f}')

