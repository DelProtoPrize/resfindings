import pandas as pd

df = pd.read_csv('bird_tracking_1.csv')
storks = df[df['Species'] == 'Stork']

# Show all observation_quality values for Storks, case-sensitive
print('=== Raw value counts (case-sensitive) ===')
print(storks['Observation_Quality'].value_counts())
print()

# Show the offending row(s) explicitly
print('=== Rows with all-caps LOW ===')
print(storks[storks['Observation_Quality'] == 'LOW'][['Bird_ID', 'Species', 'Observation_Quality']])
print()

# Side-by-side strict vs cleaned counts
strict = ((df['Species'] == 'Stork') & (df['Observation_Quality'] == 'Low')).sum()
cleaned = ((df['Species'] == 'Stork') & (df['Observation_Quality'].str.lower() == 'low')).sum()

print('=== Final comparison ===')
print(f'Strict ("Low" only):           {strict}')
print(f'Cleaned ("Low" + "LOW"):       {cleaned}')
print(f'Difference (data quality bug):  {cleaned - strict}')


import pandas as pd

df = pd.read_csv('bird_tracking_1.csv')

# Filter to Lost Signal interruptions
lost_signal = df[df['Interrupted_Reason'] == 'Lost Signal']

# Group by Habitat + Weather, count, sort
combo_counts = (lost_signal
                .groupby(['Habitat', 'Weather_Condition'])
                .size()
                .sort_values(ascending=False))

# Get the top combo
habitat, weather = combo_counts.idxmax()
print(f'{habitat} + {weather}')   # Forest + Windy


import pandas as pd

df = pd.read_csv('bird_tracking_1.csv')

# Filter to birds with at least 1 rest stop
birds = df[df['Rest_Stops'] >= 1]

# Rate = sum of predator sightings / sum of rest stops, by region
rates = (birds.groupby('Region')
              .apply(lambda g: g['Predator_Sightings'].sum() / g['Rest_Stops'].sum())
              .sort_values(ascending=False))

winner = rates.idxmax()
print(f'{winner} ({rates.max():.4f})')   # Australia (0.6254)
